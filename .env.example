# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Claude model used to summarize agendas/minutes
SUMMARIZATION_MODEL=claude-sonnet-5

# Optional — SMTP email notifications.
# Recipients come from the on-site subscribers table (see /subscribe). EMAIL_TO
# is an optional static fallback/admin list (comma-separated) that always
# receives notifications; leave it blank to send to subscribers only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Optional — Bluesky notifications
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional — App settings
SCRAPE_INTERVAL_MINUTES=60
# Historical backfill: re-scrape this many prior years (0 disables) on an interval
BACKFILL_YEARS=2
BACKFILL_INTERVAL_HOURS=168
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///data/council.db
PDF_STORAGE_DIR=data/pdfs
