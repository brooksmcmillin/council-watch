# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — City being monitored (CITY_-prefixed). Defaults describe Campbell, CA.
# Override these to point the scraper/summarizer/notifier at another CivicPlus city
# without touching code.
# CITY_NAME=Campbell                          # short name (email subjects, User-Agent)
# CITY_LOCATION=Campbell, California          # how the city reads in summarizer prompts
# CITY_DISPLAY_NAME=Campbell City Council     # display name in notifications
# CITY_BASE_URL=https://www.campbellca.gov    # CivicPlus site root (no trailing slash)
# CITY_AGENDA_PATH=City-Council-10            # AgendaCenter category path segment
# CITY_CATEGORY_ID=10                         # CivicPlus catID for the backfill endpoint
# CITY_USER_AGENT=CampbellCouncilMonitor/1.0 (+https://github.com/brooksmcmillin/council-meetings)

# Optional — Claude model used to summarize agendas/minutes
SUMMARIZATION_MODEL=claude-sonnet-5

# Optional — SMTP email notifications.
# Recipients come from the on-site subscribers table (see /subscribe). EMAIL_TO
# is an optional static fallback/admin list (comma-separated) that always
# receives notifications; leave it blank to send to subscribers only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Optional — Bluesky notifications
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional — App settings
SCRAPE_INTERVAL_MINUTES=60
# Historical backfill: re-scrape this many prior years (0 disables) on an interval
BACKFILL_YEARS=2
BACKFILL_INTERVAL_HOURS=168
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///data/council.db
PDF_STORAGE_DIR=data/pdfs
